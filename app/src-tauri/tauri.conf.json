{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI News Collection",
  "version": "0.1.0",
  "identifier": "local.news-collection.ai-digest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI News Collection",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/digest-sidecar"
    ]
  }
}
