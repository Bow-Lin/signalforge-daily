{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SignalForge Daily",
  "version": "0.4.0",
  "identifier": "com.signalforge.daily",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SignalForge Daily",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "SignalForge Daily",
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/digest-sidecar"
    ]
  }
}
